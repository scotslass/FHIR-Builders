# ──────────────────────────────────────────────────────────────────────────
# my-fhir-app — environment variables
# Copy this file to .env and fill in real values. DO NOT commit .env.
# ──────────────────────────────────────────────────────────────────────────

# --- Medplum FHIR server ---
# Base URL of the Medplum FHIR API. For the hosted service this is:
#   https://api.medplum.com/
# For a self-hosted instance, point at your server's /fhir/R4 base.
MEDPLUM_BASE_URL=https://api.medplum.com/fhir/R4

# OAuth2 client-credentials grant. Create a ClientApplication in Medplum and
# copy its id/secret here. The client needs read access to the resources you
# intend to evaluate.
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# --- Paths (override the defaults under the project root) ---
DATA_RAW_DIR=data/raw
DATA_EXPORTS_DIR=data/exports
OUTPUTS_DIR=outputs
RESULT_STORE_DB=db/stores/quality_results.duckdb
